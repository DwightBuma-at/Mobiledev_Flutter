{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flutter Android Emulator",
      "request": "launch",
      "type": "dart",
      "deviceId": "emulator-5554"
    },
    {
      "name": "Flutter Web Server (Port 8766)",
      "request": "launch",
      "type": "dart",
      "deviceId": "web-server",
      "toolArgs": [
        "--web-hostname",
        "127.0.0.1",
        "--web-port",
        "8766"
      ]
    },
    {
      "name": "Flutter Web (Chrome - Port 8766)",
      "request": "launch",
      "type": "dart",
      "deviceId": "chrome",
      "toolArgs": [
        "--web-hostname",
        "127.0.0.1",
        "--web-port",
        "8766"
      ]
    }
  ]
}
